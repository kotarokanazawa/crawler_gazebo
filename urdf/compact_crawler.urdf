<?xml version="1.0" encoding="UTF-8"?>
<robot name="crawler">

  <material name="base_gray"><color rgba="0.45 0.47 0.50 1"/></material>
  <material name="track_green"><color rgba="0.224 0.72 0.556 1"/></material>
  <material name="flipper_blue"><color rgba="0.008 0.416 0.7 1"/></material>
  <material name="pulley_dark"><color rgba="0.10 0.10 0.10 1"/></material>


  <link name="base_link">
    <visual>
      <geometry><box size="0.36 0.16 0.09"/></geometry>
      <material name="base_gray"/>
    </visual>

    <collision>
      <geometry><box size="0.36 0.16 0.09"/></geometry>
    </collision>
    <inertial>
      <mass value="3"/>
      <inertia ixx="0.008425" ixy="0" ixz="0" iyy="0.034425" iyz="0" izz="0.0388"/>
    </inertial>
  </link>


  <joint name="base_link2body_belt_left" type="fixed">
    <parent link="base_link"/>
    <child link="main_body_left"/>
    <origin xyz="0 0.095 0" rpy="0 0 0"/>
  </joint>

  <link name="main_body_left">
    <visual>
      <geometry><box size="0.36 0.08 0.13"/></geometry>
      <material name="track_green"/>
    </visual>

    <inertial>
      <mass value="18"/>
      <inertia ixx="0.03495" ixy="0" ixz="0" iyy="0.21975" iyz="0" izz="0.204"/>
    </inertial>
  </link>

  <link name="sprocket_left">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079633 0 0"/>
      <geometry><cylinder radius="0.065" length="0.08"/></geometry>
      <material name="pulley_dark"/>
    </visual>

    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.00019075" ixy="0" ixz="0" iyy="0.0002535" iyz="0" izz="0.00019075"/>
    </inertial>
  </link>

  <joint name="sprocket_axle_left" type="continuous">
    <parent link="main_body_left"/>
    <child link="sprocket_left"/>
    <origin xyz="0.18 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="1000" velocity="100"/>
  </joint>

  <link name="idler_left">
