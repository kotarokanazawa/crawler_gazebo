    <inertial>
      <mass value="0.12"/>
      <inertia ixx="0.00019075" ixy="0" ixz="0" iyy="0.0002535" iyz="0" izz="0.00019075"/>
    </inertial>
  </link>

  <joint name="idler_axle_left" type="fixed">
    <parent link="main_body_left"/>
    <child link="idler_left"/>
    <origin xyz="-0.18 0 0" rpy="0 0 0"/>
