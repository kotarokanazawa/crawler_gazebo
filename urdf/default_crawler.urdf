    <plugin name="track_right" filename="libContinuousTrack.so">
      <sprocket>
        <joint>sprocket_axle_right</joint>
        <pitch_diameter>0.24</pitch_diameter>
      </sprocket>
      <trajectory>
        <segment><joint>track_right_straight_segment_joint0</joint><end_position>0.45</end_position></segment>
        <segment><joint>track_right_arc_segment_joint0</joint><end_position>3.14159265</end_position></segment>
        <segment><joint>track_right_straight_segment_joint1</joint><end_position>0.45</end_position></segment>
        <segment><joint>track_right_arc_segment_joint1</joint><end_position>3.14159265</end_position></segment>
      </trajectory>
      <pattern>
        <elements_per_round>40</elements_per_round>
        <element/>
      </pattern>
    </plugin>
  </gazebo>


