<?xml version="1.0" encoding="UTF-8"?>
<robot name="crawler">

  <material name="base_gray"><color rgba="0.45 0.47 0.50 1"/></material>
  <material name="track_green"><color rgba="0.224 0.72 0.556 1"/></material>
  <material name="flipper_blue"><color rgba="0.008 0.416 0.7 1"/></material>
  <material name="pulley_dark"><color rgba="0.10 0.10 0.10 1"/></material>


  <link name="base_link">
    <visual>
      <geometry><box size="0.58 0.26 0.14"/></geometry>
      <material name="base_gray"/>
    </visual>

    <collision>
      <geometry><box size="0.58 0.26 0.14"/></geometry>
    </collision>
    <inertial>
      <mass value="8.5"/>
      <inertia ixx="0.0617666667" ixy="0" ixz="0" iyy="0.252166667" iyz="0" izz="0.286166667"/>
    </inertial>
  </link>


  <joint name="base_link2body_belt_left" type="fixed">
    <parent link="base_link"/>
    <child link="main_body_left"/>
    <origin xyz="0 0.155 0" rpy="0 0 0"/>
  </joint>

  <link name="main_body_left">
    <visual>
      <geometry><box size="0.58 0.13 0.21"/></geometry>
      <material name="track_green"/>
    </visual>

    <inertial>
      <mass value="50"/>
      <inertia ixx="0.254166667" ixy="0" ixz="0" iyy="1.58541667" iyz="0" izz="1.47208333"/>
    </inertial>
  </link>

  <link name="sprocket_left">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079633 0 0"/>
      <geometry><cylinder radius="0.105" length="0.13"/></geometry>
      <material name="pulley_dark"/>
    </visual>

    <inertial>
      <mass value="0.34"/>
      <inertia ixx="0.00141595833" ixy="0" ixz="0" iyy="0.00187425" iyz="0" izz="0.00141595833"/>
    </inertial>
  </link>

  <joint name="sprocket_axle_left" type="continuous">
    <parent link="main_body_left"/>
    <child link="sprocket_left"/>
    <origin xyz="0.29 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="1500" velocity="100"/>
  </joint>

  <link name="idler_left">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079633 0 0"/>
      <geometry><cylinder radius="0.105" length="0.13"/></geometry>
      <material name="pulley_dark"/>
    </visual>

    <inertial>
      <mass value="0.34"/>
      <inertia ixx="0.00141595833" ixy="0" ixz="0" iyy="0.00187425" iyz="0" izz="0.00141595833"/>
    </inertial>
  </link>

  <joint name="idler_axle_left" type="fixed">
    <parent link="main_body_left"/>
    <child link="idler_left"/>
    <origin xyz="-0.29 0 0" rpy="0 0 0"/>
  </joint>


  <joint name="base_link2body_belt_right" type="fixed">
