      <pose>0 0 -0.131 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <use_parent_model_frame>0</use_parent_model_frame>
      </axis>
      <physics><ode><implicit_spring_damper>1</implicit_spring_damper></ode></physics>
    </joint>
  </gazebo>

  <gazebo>
    <joint name="flipper_track_right_rear_arc_segment_joint1" type="revolute">
      <parent>flipper_body_right_rear</parent>
      <child>flipper_track_right_rear_arc_segment_link1</child>
      <pose>0 0 -0.131 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <use_parent_model_frame>0</use_parent_model_frame>
      </axis>
      <physics><ode><implicit_spring_damper>1</implicit_spring_damper></ode></physics>
    </joint>
  </gazebo>

  <gazebo>
    <plugin name="flipper_track_right_rear" filename="libContinuousTrack.so">
      <sprocket>
        <joint>flipper_sprocket_axle_right_rear</joint>
        <pitch_diameter>0.31</pitch_diameter>
      </sprocket>
      <trajectory>
        <segment><joint>flipper_track_right_rear_straight_segment_joint0</joint><end_position>0.37</end_position></segment>
        <segment><joint>flipper_track_right_rear_arc_segment_joint0</joint><end_position>3.14159265</end_position></segment>
        <segment><joint>flipper_track_right_rear_straight_segment_joint1</joint><end_position>0.37</end_position></segment>
        <segment><joint>flipper_track_right_rear_arc_segment_joint1</joint><end_position>3.14159265</end_position></segment>
      </trajectory>
      <pattern>
        <elements_per_round>24</elements_per_round>
        <element/>
      </pattern>
    </plugin>
  </gazebo>


  <link name="imu_frame">
    <visual>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
      <material name="base_gray"/>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <gazebo reference="imu_frame">
    <sensor name="imu" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <topicName>/imu_data/data</topicName>
        <bodyName>remote_robot/imu_frame</bodyName>
        <updateRateHZ>100.0</updateRateHZ>
        <gaussianNoise>0.0</gaussianNoise>
        <xyzOffset>0 0 0</xyzOffset>
        <rpyOffset>0 0 0</rpyOffset>
        <frameName>remote_robot/imu_frame</frameName>
        <initialOrientationAsReference>false</initialOrientationAsReference>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>


  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="sprocket_axle_left">

      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="sprocket_axle_right">

      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="flipper_sprocket_axle_left_front">

      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="flipper_sprocket_axle_left_rear">

      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="flipper_sprocket_axle_right_front">

      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="flipper_sprocket_axle_right_rear">

      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_left_front">

      <param name="pos_kp">300</param>
      <param name="pos_ki">0</param>
      <param name="pos_kd">95</param>
      <param name="pos_max_integral_error">1000</param>
      <command_interface name="position_pid"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_left_rear">

      <param name="pos_kp">300</param>
      <param name="pos_ki">0</param>
      <param name="pos_kd">95</param>
      <param name="pos_max_integral_error">1000</param>
      <command_interface name="position_pid"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_right_front">

      <param name="pos_kp">300</param>
      <param name="pos_ki">0</param>
      <param name="pos_kd">95</param>
      <param name="pos_max_integral_error">1000</param>
      <command_interface name="position_pid"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_right_rear">

      <param name="pos_kp">300</param>
      <param name="pos_ki">0</param>
      <param name="pos_kd">95</param>
      <param name="pos_max_integral_error">1000</param>
      <command_interface name="position_pid"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>


  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>__CRAWLER_ROS2_CONTROL_YAML__</parameters>
    </plugin>
  </gazebo>

</robot>
